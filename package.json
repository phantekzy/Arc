{
  "name": "@phantekzy/arc",
  "version": "1.1.2",
  "description": "Minimalist multi-core web framework for Node.js",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch server.ts",
    "build": "rm -rf dist && tsc",
    "start": "node --env-file=.env dist/server.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jsonwebtoken": "9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.11.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.3.3"
  }
}
